<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.techpulse.learn.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.techpulse.learn.entity.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="price" column="price"/>
    </resultMap>

    <select id="getAllProducts" resultMap="ProductResultMap">
        SELECT * FROM products
    </select>

    <select id="getProductById" parameterType="int" resultMap="ProductResultMap">
        SELECT * FROM products WHERE id = #{id}
    </select>

    <insert id="insertProduct" parameterType="com.techpulse.learn.entity.Product">
        INSERT INTO products (name, description, price)
        VALUES (#{name}, #{description}, #{price})
    </insert>

    <update id="updateProduct" parameterType="com.techpulse.learn.entity.Product">
        UPDATE products
        SET name = #{name},
        description = #{description},
        price = #{price}
        WHERE id = #{id}
    </update>

    <delete id="deleteProduct" parameterType="int">
        DELETE FROM products WHERE id = #{id}
    </delete>


</mapper>


