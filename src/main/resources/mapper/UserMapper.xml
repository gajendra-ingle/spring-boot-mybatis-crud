<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.techpulse.learn.mapper.UserMapper">

    <select id="findById" parameterType="long" resultType="com.techpulse.learn.entity.User">
        SELECT
        id,
        name,
        email,
        is_deleted AS isDeleted
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findAll" resultType="com.techpulse.learn.entity.User">
        SELECT id, name, email, is_deleted AS isDeleted
        FROM users
    </select>

    <insert id="insertUser" parameterType="com.techpulse.learn.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (name, email)
        VALUES (#{name}, #{email})
    </insert>

    <delete id="deleteUser" parameterType="long">
        DELETE FROM users WHERE id = #{id}
    </delete>

    <select id="searchUsersByName" resultType="com.techpulse.learn.entity.User">
        SELECT *
        FROM users
        WHERE LOWER(name) LIKE CONCAT('%', LOWER(#{name}), '%')
    </select>

    <!-- Soft Delete -->
    <update id="softDeleteUser" parameterType="long">
        UPDATE users
        SET is_deleted = sa
        WHERE id = #{id}
        AND is_deleted = 0
    </update>

    <!-- Find Only Active Users -->
    <select id="findAllActiveUsers" resultType="com.techpulse.learn.entity.User">
        SELECT id, name, email, is_deleted
        FROM users
        WHERE is_deleted = 0
    </select>

    <select id="countUsers" resultType="long">
        SELECT COUNT(*)
        FROM users
        WHERE is_deleted = 0
    </select>


</mapper>