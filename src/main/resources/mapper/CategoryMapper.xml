<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.techpulse.learn.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.techpulse.learn.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
    </resultMap>

    <select id="getAllCategories" resultMap="CategoryResultMap">
        SELECT * FROM categories
    </select>

    <select id="getCategoryById" parameterType="int" resultMap="CategoryResultMap">
        SELECT * FROM categories WHERE id = #{id}
    </select>

    <insert id="insertCategory" parameterType="com.techpulse.learn.entity.Category">
        INSERT INTO categories (name, description) VALUES (#{name}, #{description})
    </insert>

    <update id="updateCategory" parameterType="com.techpulse.learn.entity.Category">
        UPDATE categories SET name = #{name}, description = #{description} WHERE id = #{id}
    </update>

    <delete id="deleteCategory" parameterType="int">
        DELETE FROM categories WHERE id = #{id}
    </delete>

</mapper>